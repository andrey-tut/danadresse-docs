{
  "name": "@danadresse/mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Danadresse — Danish address API. Gives Claude Desktop / Claude Code / Cursor / Continue direct access to autocomplete, validation, reverse geocoding, DAGI, BBR and address-quality scoring across all 2.4M Danish addresses.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "danadresse-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --test --import tsx src/__tests__/*.test.ts",
    "test:integration": "INTEGRATION=1 node --test --import tsx src/__tests__/integration.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "danadresse",
    "dawa",
    "denmark",
    "danish",
    "address",
    "geocoding",
    "claude",
    "cursor",
    "ai-agent"
  ],
  "author": "LynBro ApS <hello@lynbro.dk>",
  "license": "MIT",
  "homepage": "https://github.com/andrey-tut/danadresse/tree/main/mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-tut/danadresse.git",
    "directory": "mcp-server"
  },
  "bugs": {
    "url": "https://github.com/andrey-tut/danadresse/issues"
  }
}
